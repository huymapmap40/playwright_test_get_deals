{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(echo \"exit: $?\")",
      "Bash(grep -E \"^\\\\.env$\")",
      "Bash(git grep *)",
      "Bash(docker manifest *)",
      "Bash(echo \"---exit:$?---\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Tool used at $(date)\" >> /tmp/hook-test.log"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true
  },
  "companyAnnouncements": [
    "🎭🛒 Welcome to project Playwright test get deals app! ✨"
  ]
}
